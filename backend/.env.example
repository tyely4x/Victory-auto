# ==============================================================
#  VICTORY AUTO SALES — BACKEND ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ==============================================================

# ── SERVER ──────────────────────────────────────────────────
PORT=3000

# ── META / FACEBOOK ─────────────────────────────────────────
# A random string YOU choose. Enter it when registering your webhook in the Meta Developer Portal.
META_VERIFY_TOKEN=victory-auto-secret-webhook-token-change-this

# From: Meta Developer Portal → Your App → Settings → Basic → App Secret
META_APP_SECRET=

# From: Meta Developer Portal → Your App → Messenger Settings → Page Access Token
# (Or from Graph API Explorer)
PAGE_ACCESS_TOKEN=

# ── OPENAI ──────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Uses gpt-4o-mini (~$0.01-0.05 per lead analyzed)
# If left blank, the app falls back to rule-based analysis (free but less accurate)
OPENAI_API_KEY=
